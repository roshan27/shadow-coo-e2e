# Copy to .env and fill in values for local development.
# All values shown are the defaults — only override what differs.

# Service base URLs (match docker-compose port mappings)
RBAC_URL=http://localhost:8007
GRAPH_URL=http://localhost:8003
KPI_REGISTRY_URL=http://localhost:8004
KPI_ENGINE_URL=http://localhost:8005
MEMORY_URL=http://localhost:8006

# COO orchestrator (only needed for test_3_coo_brief.py)
COO_ORCHESTRATOR_URL=http://localhost:8008

# Database (postgres-main from docker-compose.infra.yml)
DB_URL=postgresql+psycopg://shadow_coo:shadow_coo_dev@localhost:5432/shadow_coo

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shadow_coo_dev

# API key used in X-API-Key headers
API_KEY=dev-key-change-in-production

# LLM key — required for test_3_coo_brief.py only
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
